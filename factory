def cmd_review(args: argparse.Namespace) -> Report:
    report = Report(command="review")
    diff = run_cmd(
        "git diff",
        ["git", "diff", "--name-only", args.base],
        note=f"changed files vs {args.base}",
    )
    staged = run_cmd("git diff staged", ["git", "diff", "--name-only", "--cached"])
    untracked = run_cmd("git untracked", ["git", "ls-files", "--others", "--exclude-standard"])
    changed = sorted(
        {
            *diff.output.split(),
            *staged.output.split(),
            *untracked.output.split(),
        }
    )
    report.data["changed_files"] = changed

    violations: list[str] = []
    for path in changed:
        for protected in PROTECTED_PATHS:
            if path == protected or path.startswith(protected):
                violations.append(path)
        if re.search(r"(^|/)model/[^/]+\.(md|yaml|yml)$", path):
            violations.append(f"{path} (canonical model data — P6, needs L3 + PatchProposal path)")
    report.results.append(
        CmdResult(
            "protected paths",
            ["<diff>"],
            1 if violations else 0,
            "\n".join(violations),
            note="none touched" if not violations else f"{len(violations)} violation(s)",
        )
    )

    checklist = [
        "G1 product scope: change traces to docs/factory/NORTH_STAR.md and its issue (P3)",
        "G2 architecture: consistent with docs/architecture/ARCHITECTURE_DECISIONS.md; no duplication (P2)",
        "G3 security/privacy: no secrets, no new network calls, no PII in fixtures",
        "P1 tests strengthened, never weakened (no deleted/skipped/loosened tests)",
        "P4 north star and factory policies untouched",
        "P5 no forbidden shapes (chatbot, workflow engine, SaaS, auth, SAP write-back)",
        "P6 no canonical model/ edits (enforced above)",
        "P7 no tags, version bumps, or release publishing",
        "P8 protected paths untouched (enforced above)",
        "P9 every claim in commit/issue matches a command actually run",
        "P10 diff contains only in-scope files",
    ]
    report.data["critical_review_checklist"] = checklist
    report.results.append(
        CmdResult(
            "review checklist",
            ["<manual>"],
            0,
            "",
            note=f"{len(checklist)} items to answer honestly (see --json or docs/factory/policies)",
        )
    )
    if not args.json:
        print("Critical-review checklist (answer each before committing):")
        for item in checklist:
            print(f"  [ ] {item}")
    return report


