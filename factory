def gate_commands(selection: set[str], include_website: bool, website_path: str) -> list[tuple[str, list[str], int]]:
    """Return (gate_name, command, timeout) tuples for the selected gates."""
    python = venv_tool("python")
    ruff = venv_tool("ruff")
    martenweave = venv_tool("martenweave")
    npm = [shutil.which("npm") or ""]

    gates: list[tuple[str, list[str], int]] = []
    if "lint" in selection:
        gates.append(("G6 ruff check", ruff + ["check", "."], 300))
        gates.append(("G6 ruff format", ruff + ["format", "--check", "src", "tests"], 300))
    if "tests" in selection:
        gates.append(("G5 pytest", python + ["-m", "pytest", "-q"], 1800))
    if "build" in selection:
        gates.append(("G6 package build", python + ["-m", "build"], 600))
    if "contracts" in selection:
        gates.append((
            "G7 api/mcp contracts",
            python + ["-m", "pytest", "tests/test_api_contract.py", "tests/test_api.py",
                      "tests/test_mcp_server.py", "-q"],
            900,
        ))
    if "examples" in selection:
        for example in EXAMPLES:
            gates.append((
                f"G4 validate {example}",
                martenweave + ["validate", "--repo", f"examples/{example}"],
                300,
            ))
    if "security" in selection:
        gates.append((
            "G3 secret guardrails",
            python + ["-m", "pytest", "tests/test_secret_guardrails.py", "-q"],
            300,
        ))
    if "docs" in selection:
        gates.append(("G10 doc commands", python + ["scripts/validate_doc_commands.py"], 120))
        gates.append(("G10 skills structure", python + ["scripts/validate_skills.py"], 120))
    if "northstar" in selection:
        gates.append(("G8 northstar demo", ["bash", "scripts/demo_northstar_pilot.sh"], 900))
    if "workbench" in selection:
        gates.append(("G9 npm ci", npm + ["--prefix", "frontend", "ci"], 900))
        gates.append(("G9 workbench build", npm + ["--prefix", "frontend", "run", "build"], 600))
        gates.append(("G9 workbench tests", npm + ["--prefix", "frontend", "test"], 600))
    if include_website and "website" in selection:
        site = website_path
        gates.append(("G10 website build", npm + ["--prefix", site, "ci"], 900))
        gates.append(("G10 website build+validate", npm + ["--prefix", site, "run", "build"], 600))
        gates.append(("G10 website render smoke", npm + ["--prefix", site, "run", "test:render"], 600))
    return gates


ALL_GATES = {
    "lint", "tests", "build", "contracts", "examples",
    "security", "docs", "northstar", "workbench", "website",
}


def cmd_validate(args: argparse.Namespace) -> Report:
    report = Report(command="validate")
    selection = set(args.gates.split(",")) if args.gates else set(ALL_GATES)
    unknown = selection - ALL_GATES
    if unknown:
        report.results.append(
            CmdResult("gate selection", ["<args>"], 1, f"unknown gates: {sorted(unknown)}")
        )
        return report
    if not args.website:
        selection.discard("website")

    website_path = args.website_path
    for name, command, timeout in gate_commands(selection, args.website, website_path):
        result = run_cmd(name, command, timeout=timeout)
        if name.startswith("G5 pytest"):
            result.note = pytest_count(result.output)
        report.results.append(result)
        if not result.ok and args.fail_fast:
            report.results.append(
                CmdResult("fail-fast", ["<stop>"], 0, "", skipped=True,
                          note="stopping after first failure")
            )
            break
    passed = sum(1 for r in report.results if r.returncode == 0 and not r.skipped)
    failed = sum(1 for r in report.results if r.returncode != 0)
    report.data["summary"] = f"gates: {passed} passed, {failed} failed"
    return report


