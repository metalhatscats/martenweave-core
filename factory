def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="factory",
        description="Martenweave Development AI Factory harness (docs/factory/).",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    def add_json(p: argparse.ArgumentParser) -> None:
        p.add_argument("--json", action="store_true", help="machine-readable output")

    p_audit = sub.add_parser("audit", help="L0 repo/doc/backlog inspection")
    add_json(p_audit)
    p_audit.add_argument("--quick", action="store_true", help="skip gate commands")
    p_audit.set_defaults(func=cmd_audit)

    p_plan = sub.add_parser("plan", help="rank open agent-ready issues")
    add_json(p_plan)
    p_plan.add_argument("--issues-json", help="read issues from a JSON file instead of gh")
    p_plan.set_defaults(func=cmd_plan)

    p_next = sub.add_parser("run-next", help="execution brief for the top issue")
    add_json(p_next)
    p_next.add_argument("--issues-json", help="read issues from a JSON file instead of gh")
    p_next.set_defaults(func=cmd_run_next)

    p_review = sub.add_parser("review", help="diff hygiene + critical-review checklist")
    add_json(p_review)
    p_review.add_argument("--base", default="HEAD", help="git base for the diff (default: HEAD)")
    p_review.set_defaults(func=cmd_review)

    p_validate = sub.add_parser("validate", help="run deterministic gates G3-G10")
    add_json(p_validate)
    p_validate.add_argument(
        "--gates",
        help=f"comma-separated subset of: {', '.join(sorted(ALL_GATES))}",
    )
    p_validate.add_argument("--fail-fast", action="store_true", help="stop at first failure")
    p_validate.add_argument("--website", action="store_true", help="include website gates")
    p_validate.add_argument(
        "--website-path",
        default=str(REPO_ROOT.parent / "martenweave.github.io"),
        help="path to the website repo (default: sibling checkout)",
    )
    p_validate.set_defaults(func=cmd_validate)

    p_release = sub.add_parser("release-check", help="G11 release evidence (read-only)")
    add_json(p_release)
    p_release.add_argument("--tag", help="candidate tag for release_preflight, e.g. v0.7.0")
    p_release.set_defaults(func=cmd_release_check)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    report: Report = args.func(args)
    if args.command not in {"run-next", "review"} or args.json:
        report.emit(args.json)
    elif args.command == "review":
        report.emit(args.json)
    ok = report.ok
    if args.command in {"plan", "run-next"}:
        ok = True if args.command == "plan" else report.ok
    return 0 if ok else 1


if __name__ == "__main__":
    sys.exit(main())
