def load_issues(args: argparse.Namespace) -> tuple[list[dict], str]:
    """Return (issues, note). Reads from --issues-json file or `gh`."""
    if getattr(args, "issues_json", None):
        path = Path(args.issues_json)
        if not path.is_file():
            return [], f"issues file not found: {path}"
        return json.loads(path.read_text(encoding="utf-8")), f"read from {path}"

    gh = shutil.which("gh")
    if not gh:
        return [], "gh CLI not found; install gh or pass --issues-json <file>"
    proc = subprocess.run(
        [
            gh, "issue", "list",
            "--label", "agent-ready",
            "--state", "open",
            "--limit", "50",
            "--json", "number,title,labels,createdAt",
        ],
        cwd=REPO_ROOT,
        capture_output=True,
        text=True,
        timeout=60,
    )
    if proc.returncode != 0:
        return [], f"gh issue list failed: {proc.stderr.strip()[:200]}"
    issues = json.loads(proc.stdout or "[]")
    for issue in issues:
        issue["labels"] = [lbl["name"] for lbl in issue.get("labels", [])]
    return issues, "gh issue list --label agent-ready"


def rank_class(labels: list[str]) -> tuple[int, str]:
    lowered = {lbl.lower() for lbl in labels}
    for idx, (name, keys) in enumerate(RANK_CLASSES):
        if lowered & set(keys):
            return idx, name
    return len(RANK_CLASSES), "other"


def rank_issues(issues: list[dict]) -> list[dict]:
    def key(issue: dict) -> tuple:
        cls, _ = rank_class(issue.get("labels", []))
        return (cls, issue.get("createdAt", ""), issue.get("number", 0))

    ranked = sorted(issues, key=key)
    for issue in ranked:
        _, issue["rank_class"] = rank_class(issue.get("labels", []))
    return ranked


def agent_for(labels: list[str]) -> str:
    for lbl in labels:
        key = LABEL_AGENT_MAP.get(lbl.lower())
        if key:
            return AGENT_FILES[key]
    return AGENT_FILES["product"]


def cmd_plan(args: argparse.Namespace) -> Report:
    report = Report(command="plan")
    issues, note = load_issues(args)
    ranked = rank_issues(issues)
    report.data["source"] = note
    report.data["open_agent_ready"] = len(ranked)
    report.data["ranked"] = [
        {
            "number": i.get("number"),
            "title": i.get("title"),
            "labels": i.get("labels", []),
            "rank_class": i.get("rank_class"),
        }
        for i in ranked
    ]
    if not ranked:
        report.data["summary"] = (
            f"No open agent-ready issues ({note}). Run the loop: audit -> gap-regression-detection "
            "-> issue-triage to seed the backlog."
        )
        return report
    top = ranked[0]
    report.data["summary"] = (
        f"Recommended next task: #{top.get('number')} {top.get('title')} "
        f"[{top.get('rank_class')}]. Run: ./factory run-next"
    )
    report.results.append(CmdResult("backlog", ["<gh>"], 0, "", note=note))
    return report


def cmd_run_next(args: argparse.Namespace) -> Report:
    report = Report(command="run-next")
    issues, note = load_issues(args)
    ranked = rank_issues(issues)
    if not ranked:
        report.data["summary"] = f"No open agent-ready issues ({note})."
        report.results.append(CmdResult("backlog", ["<gh>"], 1, "empty backlog"))
        return report

    top = ranked[0]
    agent_file = agent_for(top.get("labels", []))
    brief = {
        "issue": top.get("number"),
        "title": top.get("title"),
        "rank_class": top.get("rank_class"),
        "responsible_agent": agent_file,
        "read_first": [
            "docs/factory/memory/PROJECT_MEMORY.md",
            "docs/factory/NORTH_STAR.md",
            "docs/factory/policies/AGENT_PREVENTIONS.md",
            agent_file,
        ],
        "skills_to_load": skills_for(top.get("labels", [])),
        "gates": "per docs/factory/policies/QUALITY_GATES.md rule 1; run ./factory validate before commit",
        "first_step": (
            f"Comment on issue #{top.get('number')} that you are taking it, then follow "
            "skills/implementation-planning/SKILL.md."
        ),
    }
    report.data["brief"] = brief
    report.data["source"] = note
    if not args.json:
        print(f"Issue #{brief['issue']}: {brief['title']}  [{brief['rank_class']}]")
        print(f"Responsible agent: {agent_file}")
        print("Read first:")
        for doc in brief["read_first"]:
            print(f"  - {doc}")
        print("Skills to load:")
        for skill in brief["skills_to_load"]:
            print(f"  - skills/{skill}/SKILL.md")
        print(f"Gates: {brief['gates']}")
        print(f"First step: {brief['first_step']}")
    return report


def skills_for(labels: list[str]) -> list[str]:
    base = ["implementation-planning", "patch-generation", "code-architecture-review"]
    lowered = {lbl.lower() for lbl in labels}
    if lowered & {"documentation", "docs"}:
        base.insert(0, "documentation-synchronization")
    if lowered & {"website"}:
        base.insert(0, "website-claim-verification")
    if lowered & {"tests", "ci", "testing"}:
        base.insert(0, "test-ci-repair")
    if lowered & {"domain", "sap"}:
        base.insert(0, "domain-pack-improvement")
    if lowered & {"ai", "mcp"}:
        base.insert(0, "ai-evaluation")
    return base


