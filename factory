@dataclass
class CmdResult:
    name: str
    command: list[str]
    returncode: int
    output: str
    skipped: bool = False
    note: str = ""

    @property
    def ok(self) -> bool:
        return self.skipped or self.returncode == 0


@dataclass
class Report:
    command: str
    results: list[CmdResult] = field(default_factory=list)
    data: dict = field(default_factory=dict)

    @property
    def ok(self) -> bool:
        return all(r.ok for r in self.results)

    def emit(self, as_json: bool) -> None:
        if as_json:
            payload = {
                "command": self.command,
                "ok": self.ok,
                "results": [
                    {
                        "name": r.name,
                        "command": " ".join(r.command),
                        "returncode": r.returncode,
                        "skipped": r.skipped,
                        "note": r.note,
                        "tail": r.output.strip().splitlines()[-3:],
                    }
                    for r in self.results
                ],
                "data": self.data,
            }
            print(json.dumps(payload, indent=2))
            return
        width = max((len(r.name) for r in self.results), default=10)
        for r in self.results:
            if r.skipped:
                status = "SKIP"
            elif r.returncode == 0:
                status = "PASS"
            else:
                status = "FAIL"
            print(f"{status}  {r.name:<{width}}  {r.note}")
            if not r.ok and r.output:
                tail = r.output.strip().splitlines()[-15:]
                for line in tail:
                    print(f"     | {line}")
        if self.data.get("summary"):
            print(self.data["summary"])


def venv_tool(name: str) -> list[str]:
    candidate = VENV_BIN / name
    if candidate.is_file() and os.access(candidate, os.X_OK):
        return [str(candidate)]
    if name == "python":
        for alt in ("python3", "python"):
            found = shutil.which(alt)
            if found:
                return [found]
        return [sys.executable]
    found = shutil.which(name)
    return [found] if found else []


def run_cmd(name: str, command: list[str], timeout: int = 600, note: str = "") -> CmdResult:
    if not command or not command[0]:
        return CmdResult(name, command or ["<missing>"], 0, "", skipped=True,
                         note="tool not found; install it and re-run")
    try:
        proc = subprocess.run(
            command,
            cwd=REPO_ROOT,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        return CmdResult(name, command, 1, f"TIMEOUT after {timeout}s", note=note)
    output = (proc.stdout or "") + (proc.stderr or "")
    return CmdResult(name, command, proc.returncode, output, note=note)


def pytest_count(output: str) -> str:
    match = re.search(r"(\d+ passed.*?)(?:\s+in\s+[\d.]+s|$)", output)
    return match.group(1) if match else ""


