def cmd_release_check(args: argparse.Namespace) -> Report:
    report = Report(command="release-check")
    python = venv_tool("python")

    version_py = (REPO_ROOT / "src/modelops_core/__version__.py").read_text(encoding="utf-8")
    match = re.search(r'"(\d+\.\d+\.\d+)"', version_py)
    source_version = match.group(1) if match else "unknown"
    pyproject = (REPO_ROOT / "pyproject.toml").read_text(encoding="utf-8")
    py_match = re.search(r'^version\s*=\s*"(\d+\.\d+\.\d+)"', pyproject, re.MULTILINE)
    py_version = py_match.group(1) if py_match else "unknown"
    consistent = source_version == py_version
    report.results.append(
        CmdResult(
            "version consistency",
            ["<fs>"],
            0 if consistent else 1,
            "",
            note=f"__version__.py={source_version} pyproject={py_version}",
        )
    )

    report.results.append(
        run_cmd("G11 release smoke", ["bash", "scripts/release_smoke.sh"], timeout=1800)
    )
    if args.tag:
        report.results.append(
            run_cmd("G11 release preflight", python + ["scripts/release_preflight.py", "--tag", args.tag], timeout=300)
        )
    report.data["summary"] = (
        "Evidence only. Releases require a maintainer-pushed v* tag (P7); "
        "this command never tags, bumps, or publishes."
    )
    return report


