def cmd_audit(args: argparse.Namespace) -> Report:
    report = Report(command="audit")

    git = run_cmd("git status", ["git", "status", "--short", "--branch"], note="working tree")
    report.results.append(git)
    dirty = [ln for ln in git.output.splitlines() if ln and not ln.startswith("##")]
    report.data["working_tree"] = "clean" if not dirty else f"{len(dirty)} uncommitted path(s)"

    missing_docs = [p for p in FACTORY_DOCS if not (REPO_ROOT / p).is_file()]
    report.results.append(
        CmdResult(
            "factory docs",
            ["<fs>"],
            1 if missing_docs else 0,
            "\n".join(missing_docs),
            note="all present" if not missing_docs else f"{len(missing_docs)} missing",
        )
    )

    if args.quick:
        report.results.append(
            CmdResult("gates", ["<skipped>"], 0, "", skipped=True, note="--quick: gate commands skipped")
        )
        return report

    ruff = venv_tool("ruff")
    report.results.append(run_cmd("ruff", ruff + ["check", "."], note="lint"))
    pytest = venv_tool("python") + ["-m", "pytest", "--collect-only", "-q"]
    collect = run_cmd("pytest collect", pytest, timeout=300)
    count = re.search(r"(\d+) tests? collected", collect.output)
    collect.note = count.group(0) if count else "collection"
    report.results.append(collect)

    martenweave = venv_tool("martenweave")
    for example in EXAMPLES:
        repo = f"examples/{example}"
        if not (REPO_ROOT / repo).is_dir():
            report.results.append(
                CmdResult(f"validate {example}", ["<fs>"], 1, "example directory missing")
            )
            continue
        result = run_cmd(
            f"validate {example}",
            martenweave + ["validate", "--repo", repo],
            timeout=300,
        )
        match = re.search(r"(\d+) errors?, (\d+) warnings?", result.output)
        result.note = match.group(0) if match else ""
        report.results.append(result)

    python = venv_tool("python")
    report.results.append(
        run_cmd("doc commands", python + ["scripts/validate_doc_commands.py"], timeout=120)
    )
    report.results.append(
        run_cmd("skills structure", python + ["scripts/validate_skills.py"], timeout=120)
    )
    return report


